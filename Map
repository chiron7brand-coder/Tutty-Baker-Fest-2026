    <div class="street-label">E. DOUGLAS ST — NORTH BOUNDARY</div>
  </div>
  <!-- Exchange St -->
  <div class="street-h" style="top:244px;height:28px;">
    <div class="street-label">E. EXCHANGE ST</div>
  </div>
  <!-- Stephenson St -->
  <div class="street-h" style="top:424px;height:28px;">
    <div class="street-label">E. STEPHENSON ST</div>
  </div>
  <!-- Main St -->
  <div class="street-h" style="top:604px;height:28px;">
    <div class="street-label">E. MAIN ST</div>
  </div>
  <!-- Spring St -->
  <div class="street-h" style="top:784px;height:28px;">
    <div class="street-label">E. SPRING ST — SOUTH BOUNDARY</div>
  </div>

  <!-- STREETS - VERTICAL (N-S) -->

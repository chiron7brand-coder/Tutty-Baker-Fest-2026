       onmouseleave="hideTip()">
    <div class="zb-name" style="font-size:.58rem;">🛍 MAKER &amp; VENDOR MARKET — Stephenson (Chicago→State)</div>
  </div>

  <!-- MAKER & VENDOR MARKET — State Ave leg (Stephenson to Main) -->
  <div class="zone-block zb-market vendors zones" style="left:544px;top:452px;width:28px;height:152px;padding:4px;writing-mode:vertical-rl;"
       onmouseenter="showTip(event,'Maker & Vendor Market — State Ave Leg','By Midwest Markets & Pop-Ups · S. State Ave: Stephenson → Main St · No utilities')"
       onmouseleave="hideTip()">
    <div class="zb-name" style="font-size:.55rem;transform:rotate(180deg);white-space:nowrap;">🛍 MARKET — State Ave (Stephenson→Main)</div>
  </div>

